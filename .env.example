# --- App ---
NODE_ENV=development
# Public URL of the app (no trailing slash). Used by BetterAuth + tRPC.
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Auth ---
# openssl rand -base64 32
BETTER_AUTH_SECRET=replace-me-with-a-long-random-string

# Google OAuth (created via gcloud on this machine)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Database ---
# Path to the sqlite file. On Hetzner/Coolify mount a volume here.
DATABASE_URL=./data/mundial.db

# --- Access control ---
# Comma-separated allowlist of emails that may sign in (you + 3 friends).
ALLOWED_EMAILS=

# --- Reminders (free Telegram bot) ---
TELEGRAM_BOT_TOKEN=
# Default group chat id to post reminders into (optional)
TELEGRAM_CHAT_ID=
# Secret guarding the cron endpoint. Coolify scheduled task sends this.
CRON_SECRET=replace-me-with-a-random-string
